{
  "manifest_version": 3,
  "name": "MatuFlow Global Injector",
  "version": "1.0",
  "description": "Injects Matugen CSS variables into every webpage.",
  "permissions": ["storage"],
  "host_permissions": ["*://*/*"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["inject.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_title": "Open MatuFlow Dashboard",
    "default_popup": "dashboard/index.html"
  },
  "web_accessible_resources": [
    {
      "resources": ["dashboard/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
